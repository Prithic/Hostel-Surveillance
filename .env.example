# GuardianAI (Python FastAPI) — copy to `.env` and adjust.
# Never commit a real `.env`.

GUARDIAN_SOURCE=0
GUARDIAN_CAMERA_ID=webcam-0
GUARDIAN_DEVICE=cpu
GUARDIAN_ENABLE_CAMERA=1
GUARDIAN_CONF=0.5
GUARDIAN_CROWD=5
GUARDIAN_NIGHT_START=22
GUARDIAN_NIGHT_END=5
GUARDIAN_ADMIN_EMAIL=admin@guardian.ai
GUARDIAN_ADMIN_PASSWORD=Warden@2026
GUARDIAN_SESSION_TTL=28800

